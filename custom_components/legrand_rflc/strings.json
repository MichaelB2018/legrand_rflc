{
    "config": {
        "abort": {
            "already_configured": "[%key:common::config_flow::abort::already_configured_device%]",
            "already_in_progress": "[%key:common::config_flow::abort::already_in_progress%]",
            "no_devices_found": "[%key:common::config_flow::abort::no_devices_found%]",
            "reauth_successful": "[%key:common::config_flow::abort::reauth_successful%]",
            "reconfigure_successful": "[%key:common::config_flow::abort::reconfigure_successful%]"
        },
        "step": {
            "user": {
                "data": {
                    "host": "[%key:common::config_flow::data::host%]",
                    "password": "[%key:common::config_flow::data::password%]"
                },
                "data_description": {
                    "host": "Hostname or IP address of your LC7001 hub (default: LCM1.local).",
                    "password": "Leave empty if the hub has no password configured."
                }
            },
            "reauth_confirm": {
                "title": "Re-authenticate {host}",
                "description": "The hub at {host} requires re-authentication.",
                "data": {
                    "password": "[%key:common::config_flow::data::password%]"
                },
                "data_description": {
                    "password": "Enter the new password for the hub."
                }
            },
            "reconfigure": {
                "data": {
                    "host": "[%key:common::config_flow::data::host%]",
                    "password": "[%key:common::config_flow::data::password%]"
                },
                "data_description": {
                    "host": "Hostname or IP address of your LC7001 hub.",
                    "password": "Leave empty to keep the current password, or enter a new one."
                }
            }
        },
        "error": {
            "invalid_auth": "[%key:common::config_flow::error::invalid_auth%]",
            "invalid_host": "[%key:common::config_flow::error::invalid_host%]"
        }
    },
    "entity": {
        "light": {
            "switch": {
                "name": "Light"
            },
            "dimmer": {
                "name": "Light"
            }
        },
        "sensor": {
            "zone_count": {
                "name": "Zone count"
            },
            "time_zone": {
                "name": "Time zone"
            },
            "daylight_saving_time": {
                "name": "Daylight saving time"
            },
            "location": {
                "name": "Location"
            },
            "add_a_light": {
                "name": "Add a light mode"
            },
            "firmware_version": {
                "name": "Firmware version"
            },
            "free_memory": {
                "name": "Free memory"
            },
            "connected_clients": {
                "name": "Connected clients"
            },
            "auth_exempt": {
                "name": "Password exempt"
            }
        }
    },
    "exceptions": {
        "switch_failed": {
            "message": "Failed to switch {entity}: {error}"
        },
        "dimmer_failed": {
            "message": "Failed to control {entity}: {error}"
        }
    }
}
